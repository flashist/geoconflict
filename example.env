# Shared configuration template
#
# Copy this file to `.env` for shared, non-secret defaults.
# Keep real secrets in gitignored overlays:
#   .env.secret
#   .env.<env>.secret
#
# Deploy scripts load files in this order:
#   .env -> .env.secret -> .env.<env> -> .env.<env>.secret

# Shared deploy settings
SSH_USER=openfront
SSH_KEY=$HOME/.ssh/id_rsa
DOCKER_USERNAME=

# Environment-specific fallback settings.
# These are used when the matching value is not set in `.env.<env>`.
SERVER_HOST_DEV=
PUBLIC_HOST_DEV=
PUBLIC_PROTOCOL_DEV=http
PUBLIC_PORT_DEV=80
DEPLOYMENT_ID_DEV=dev
API_BASE_URL_DEV=
JWT_ISSUER_DEV=
JWT_AUDIENCE_DEV=

SERVER_HOST_STAGING=
PUBLIC_HOST_STAGING=
PUBLIC_PROTOCOL_STAGING=http
PUBLIC_PORT_STAGING=80
DEPLOYMENT_ID_STAGING=staging
API_BASE_URL_STAGING=
JWT_ISSUER_STAGING=
JWT_AUDIENCE_STAGING=

SERVER_HOST_PROD=
PUBLIC_HOST_PROD=
PUBLIC_PROTOCOL_PROD=https
PUBLIC_PORT_PROD=443
DEPLOYMENT_ID_PROD=prod
API_BASE_URL_PROD=
JWT_ISSUER_PROD=
JWT_AUDIENCE_PROD=

# Optional runtime configuration.
# Move credential values to `.env.secret` when they are sensitive.
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=

# Production telemetry. Leave empty outside production so dev data does not go
# to the production Uptrace instance.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_AUTH_HEADER=
OTEL_USERNAME=
OTEL_PASSWORD=
OTEL_ENDPOINT=

# Optional access gate used by deploy.sh when --enable_basic_auth is passed.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Optional feedback delivery.
FEEDBACK_WEBHOOK_URL=
FEEDBACK_TELEGRAM_TOKEN=
FEEDBACK_TELEGRAM_CHAT_ID=
TELEGRAM_PROXY_URL=

# Optional local client proxy settings.
USE_REMOTE_DEV=
DEV_REMOTE_ORIGIN=
API_DOMAIN=

# -----------------------------------------------------------
# Shared secret overlay example: .env.secret
# -----------------------------------------------------------
# DOCKER_TOKEN=
# ADMIN_TOKEN=
# API_KEY=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# OTEL_AUTH_HEADER=
# OTEL_PASSWORD=
# FEEDBACK_WEBHOOK_URL=
# FEEDBACK_TELEGRAM_TOKEN=
# TELEGRAM_PROXY_URL=

# -----------------------------------------------------------
# Per-environment overrides: .env.dev, .env.prod, etc.
# -----------------------------------------------------------
# Example .env.dev:
# VPS_IP=203.0.113.10
# DOCKER_REPO=geoconflict-dev
# PUBLIC_HOST=203.0.113.10
# PUBLIC_PROTOCOL=http
# PUBLIC_PORT=80
# DEPLOYMENT_ID=dev
# API_BASE_URL=http://203.0.113.10
# JWT_ISSUER=http://203.0.113.10
# JWT_AUDIENCE=203.0.113.10
#
# Example .env.prod:
# VPS_IP=198.51.100.25
# DOCKER_REPO=geoconflict-prod
# PUBLIC_HOST=game.example.com
# PUBLIC_PROTOCOL=https
# PUBLIC_PORT=443
# DEPLOYMENT_ID=prod
# API_BASE_URL=https://api.example.com
# JWT_ISSUER=https://game.example.com
# JWT_AUDIENCE=game.example.com

# -----------------------------------------------------------
# Per-environment secret overlay examples:
#   .env.dev.secret, .env.prod.secret
# -----------------------------------------------------------
# SSH_KEY_DEV=$HOME/.ssh/geoconflict-dev
# SSH_KEY_PROD=$HOME/.ssh/geoconflict-prod
#
# Deprecated emergency fallback only:
# ALLOW_SSH_PASSWORD_FALLBACK=1
# SSH_PASS_PROD=temporary-emergency-password
#
# Legacy VPS_LOGIN / VPS_PASSWORD variables are still accepted by deploy.sh for
# compatibility, but new templates should use SSH_USER / SSH_KEY instead.
